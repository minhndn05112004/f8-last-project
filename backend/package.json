{
  "name": "meat-shop-backend",
  "version": "1.0.0",
  "description": "Meat Shop Ecommerce Backend — Express + Prisma + Socket.io",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "prisma:migrate": "npx prisma migrate dev --name ecommerce_init",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "prisma:reset": "npx prisma migrate reset --force",
    "seed": "node prisma/seed.js",
    "setup": "npx prisma migrate dev --name ecommerce_init && node prisma/seed.js"
  },
  "keywords": [
    "ecommerce",
    "meat",
    "nodejs",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.9",
    "prisma": "^6.19.3",
    "resend": "^6.12.4",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "zod": "^3.25.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
