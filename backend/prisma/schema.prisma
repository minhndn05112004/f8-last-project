generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum ReactionType {
  LIKE
  DISLIKE
}

enum SupportStatus {
  WAITING
  ACTIVE
  COMPLETED
  CLOSED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum OrderStatus {
  PENDING_CONFIRMATION  // Chờ xác nhận
  CONFIRMED             // Đã xác nhận
  PREPARING             // Đang chuẩn bị hàng
  READY_FOR_DELIVERY    // Sẵn sàng giao (nội bộ)
  DELIVERING            // Đang giao
  DELIVERED             // Đã giao
  CANCELLED             // Đã hủy
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  username  String?  @unique
  branch    String?
  password  String
  phone     String?
  avatar    String?
  address   String?
  role      String   @default("USER") // ADMIN | STAFF | SHIPPER | USER
  isOnline           Boolean   @default(false)
  isActive           Boolean   @default(true)
  isVerified         Boolean   @default(false)
  verifyToken        String?
  verifyTokenExpiry  DateTime?
  refreshToken       String?
  refreshTokenExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders          Order[]
  cart            Cart?
  news            News[]
  products        Product[]
  newsComments    NewsComment[]
  newsReactions   NewsReaction[]

  // Relations for Support Chat
  supportRequests SupportRequest[] @relation("UserRequests")
  assignedSupport SupportRequest[] @relation("StaffRequests")
  messages        Message[]

  // Shipper assignments
  assignedOrders  Order[]          @relation("ShipperOrders")

  // Order status log (ai thay đổi)
  orderStatusLogs OrderStatusLog[]

  @@map("user")
}

// ─── PRODUCT TAG SYSTEM ───────────────────────────────────────────────────────

model ProductTag {
  id       Int    @id @default(autoincrement())
  name     String @unique
  slug     String @unique

  products ProductTagOnProduct[]
  @@map("producttag")
}

model ProductTagOnProduct {
  productId Int
  tagId     Int

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("producttagonproduct")
}

// ─── PRODUCT ──────────────────────────────────────────────────────────────────

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  slug             String   @unique
  description      String?  @db.Text
  shortDescription String?
  thumbnail        String?
  images           String   @default("[]") // JSON array as string
  price            Float
  salePrice        Float?
  stock            Int      @default(0)
  sku              String?  @unique
  isPublished      Boolean  @default(false)
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  tags       ProductTagOnProduct[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  @@map("product")
}

// ─── CART ─────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]
  @@map("cart")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  cartId Int
  cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cartitem")
}

// ─── ORDER ─────────────────────────────────────────────────────────@───────────

model Order {
  id              Int           @id @default(autoincrement())
  orderCode       String        @unique
  totalAmount     Float
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(PENDING_CONFIRMATION)
  shippingAddress String
  customerPhone   String
  customerEmail   String
  note            String?       @db.Text
  cancelReason    String?       @db.Text

  // ─── Timestamps lifecycle ─────────────────────────────────────────
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  paidAt       DateTime?
  confirmedAt  DateTime?
  preparedAt   DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?

  // ─── Relations ───────────────────────────────────────────────────
  userId              Int
  user                User                 @relation(fields: [userId], references: [id])

  assignedShipperId   Int?
  assignedShipper     User?                @relation("ShipperOrders", fields: [assignedShipperId], references: [id])

  orderItems          OrderItem[]
  paymentTransactions PaymentTransaction[]
  statusLogs          OrderStatusLog[]

  @@map("order")
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float // snapshot giá tại thời điểm mua

  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])
  @@map("orderitem")
}

// ─── NEWS ─────────────────────────────────────────────────────────────────────

model News {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String?  @db.Text
  content     String   @db.LongText
  thumbnail   String?
  views       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int
  createdBy   User          @relation(fields: [createdById], references: [id])

  comments    NewsComment[]
  reactions   NewsReaction[]
  @@map("news")
}

model NewsComment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  newsId    Int
  news      News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("newscomment")
}

model NewsReaction {
  id        Int          @id @default(autoincrement())
  type      ReactionType
  createdAt DateTime     @default(now())

  newsId    Int
  news      News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
  @@map("newsreaction")
}

// ─── SUPPORT CHAT MODELS ──────────────────────────────────────────────────────

model SupportRequest {
  id              Int           @id @default(autoincrement())
  status          SupportStatus @default(WAITING)
  title           String?
  createdAt       DateTime      @default(now())
  acceptedAt      DateTime?
  closedAt        DateTime?
  updatedAt       DateTime      @updatedAt

  userId          Int
  user            User          @relation("UserRequests", fields: [userId], references: [id])

  assignedStaffId Int?
  assignedStaff   User?         @relation("StaffRequests", fields: [assignedStaffId], references: [id])

  messages        Message[]
  @@map("supportrequest")
}

model Message {
  id               Int      @id @default(autoincrement())
  content          String
  createdAt        DateTime @default(now())

  supportRequestId Int
  supportRequest   SupportRequest @relation(fields: [supportRequestId], references: [id], onDelete: Cascade)

  senderId         Int
  sender           User @relation(fields: [senderId], references: [id])
  @@map("message")
}

model PaymentTransaction {
  id            Int      @id @default(autoincrement())
  orderId       Int
  transactionId String   @unique
  gateway       String
  amount        Float
  content       String
  rawData       String   @db.Text
  createdAt     DateTime @default(now())

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("paymenttransaction")
}

// ─── ORDER STATUS AUDIT LOG ───────────────────────────────────────────────────

model OrderStatusLog {
  id          Int          @id @default(autoincrement())
  orderId     Int
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Dùng enum để đảm bảo type-safety. fromStatus nullable cho lần tạo đầu tiên.
  fromStatus  OrderStatus?
  toStatus    OrderStatus

  changedById Int
  changedBy   User         @relation(fields: [changedById], references: [id])

  note        String?      @db.Text
  createdAt   DateTime     @default(now())

  @@map("orderstatuslog")
}
